[ T-Gshow ]
    title = generated cell array
     mesh =  xyz            # mesh type is xyz scoring mesh
   x-type =    2            # x-mesh is linear given by xmin, xmax and nx
     xmin = -6.5000000E-03  # minimum value of x-mesh points
     xmax =  6.5000000E-03  # maximum value of x-mesh points
#    xdel =  6.5000000E-05  # mesh width of x-mesh points
       nx =    200          # number of x-mesh points
   y-type =    2            # y-mesh is linear given by ymin, ymax and ny
     ymin = -6.5000000E-03  # minimum value of y-mesh points
     ymax =  6.5000000E-03  # maximum value of y-mesh points
#    ydel =  6.5000000E-05  # mesh width of y-mesh points
       ny =    200          # number of y-mesh points
   z-type =    1            # z-mesh is given by the below data
       nz =      1          # number of z-mesh points
#    data = ( z(i), i = 1, nz + 1 )
            0.00000E+00  2.55000E-03
     axis =   xy            # axis of output
     file = geometry_topview.out  # file name of output for the above axis
   output =    6            # (D=2) 1:bnd, 2:bnd+mat, 3:bnd+num 4:bnd+mat+num
    ginfo =    2            # (D=0) 0:no, 1:show in graph, 2:add file
    resol =    1            # (D=1) resolution of gshow or rshow
    width = 0.5000000       # (D=0.5) width of lines for gshow or rshow
   epsout =    1            # (D=0) generate eps file by ANGEL
#    used :        main (  %)        temp (  %)       total (  %)
#  memory :         404 (  0)       20201 (  0)       20605 (  0)

